<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>GTIN Verify</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-4">
<div class="card shadow-sm">
<div class="card-body">
<h3 class="mb-3">GTIN Bulk Verification</h3>
<form method="POST">
<div class="mb-3">
<textarea name="codes" rows="6" class="form-control" placeholder="One GTIN per line"></textarea>
</div>
<button class="btn btn-primary">Verify</button>
</form>

<% if(results){ %>
<hr>
<% const allValid = results.every(r=>r.valid); %>
<% if(allValid){ %><div class="alert alert-success">✅ All valid</div><% } %>
<ul class="list-group">
<% results.forEach(r=>{ %>
<li class="list-group-item d-flex justify-content-between">
<span><%= r.code %></span>
<% if(r.valid){ %><span class="text-success">Valid</span><%}else{%><span class="text-danger">Invalid</span><%}%>
</li>
<%}) %>
</ul>
<% } %>

</div>
</div>
</div>
</body>
</html>
